import gymnasium as gym
import highway_env  # make sure env registry 已经加载

def test_merge_test_env():
    env = gym.make("merge-test-v0", render_mode="human")
    obs, info = env.reset()

    print("初始 observation:", obs)
    print("初始 info:", info)

    max_steps = 100
    for step in range(max_steps):
        # merge-test-v0 的 _simulate() 里所有车辆自动行驶，这里 action 可传 None 或 sample
        obs, reward, terminated, truncated, info = env.step(None)

        if step % 20 == 0:
            print(f"step={step}, reward={reward}, terminated={terminated}, truncated={truncated}, vehicles={info.get('vehicles')}")

        if terminated or truncated:
            print("Episode 结束", "step=", step)
            break

    print("最终 step:", step + 1)
    env.close()

if __name__ == "__main__":
    test_merge_test_env()